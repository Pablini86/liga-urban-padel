rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in [
          'pablolc20111@gmail.com',
          'contacto@urbanpadellife.com'
        ];
    }

    // Imágenes de patrocinadores: públicas para lectura (se muestran en index.html),
    // solo admin puede subir/borrar. Limitado a imágenes de hasta 5MB.
    match /patrocinadores/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
